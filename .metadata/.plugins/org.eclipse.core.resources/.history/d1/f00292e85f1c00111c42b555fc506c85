import java.util.ArrayList;
import java.util.List;

public class Lms {

    public static class Book {
        private final String title;
        private final int price;       // in whole currency units
        private boolean available;

        public Book(String title, int price) {
            if (title == null || title.isBlank()) {
                throw new IllegalArgumentException("Title cannot be null/blank");
            }
            if (price < 0) {
                System.out.println("The price is invalid");
                // Reject creating/adding a book with negative price
                throw new IllegalArgumentException("Price cannot be negative");
            } else {
                System.out.println("The price is valid");
            }
            this.title = title;
            this.price = price;
            this.available = true;
        }

        public String getTitle() { return title; }
        public int getPrice() { return price; }
        public boolean isAvailable() { return available; }
        private void setAvailable(boolean available) { this.available = available; }

        @Override
        public String toString() {
            return title + " (Price: " + price + (available ? ", Available" : ", Borrowed") + ")";
        }
    }

    public static class Library {

        private final List<Book> books = new ArrayList<>();

        // Add a new book with title and price
        public void addBook(String title, int price) {
            books.add(new Book(title, price));
        }

        // Optional overload if you already have a Book instance
        public void addBook(Book book) {
            if (book != null) {
                books.add(book);
            }
        }

        public void borrowBook(String titleQuery) {
            Book b = find(titleQuery);
            if (b != null && b.isAvailable()) {
                b.setAvailable(false);
                System.out.println("Borrowed: " + b.getTitle());
            } else {
                System.out.println("Book not available");
            }
        }

        /**
         * Finds the first book whose title contains the query (case-insensitive).
         * Returns null if none found.
         */
        public Book find(String query) {
            if (query == null || query.isBlank()) return null;
            String q = query.toLowerCase();
            for (Book b : books) {
                if (b.getTitle().toLowerCase().contains(q)) {
                    return b;
                }
            }
            return null;
        }

        /**
         * Finds all books whose titles contain the query (case-insensitive).
         */
        public List<Book> findAll(String query) {
            List<Book> result = new ArrayList<>();
            if (query == null || query.isBlank()) return result;
            String q = query.toLowerCase();
            for (Book b : books) {
                if (b.getTitle().toLowerCase().contains(q)) {
                    result.add(b);
                }
            }
            return result;
        }

        public void displayBooks() {
            for (Book b : books) {
                if (b.isAvailable()) {
                    System.out.println(b.getTitle() + " (Price: " + b.getPrice() + ")");
                }
            }
        }
    }

   
    public static void main(String[] args) {
        Library lib = new Library();

        lib.addBook("Effective Java", 750);
        lib.addBook("Java Concurrency in Practice", 950);
        lib.addBook("Clean Code", 650);

        
        try {
            lib.addBook("Some Book", -10);
        } catch (IllegalArgumentException e) {
            System.out.println("Could not add book: " + e.getMessage());
        }

        System.out.println("\nAvailable books:");
        lib.displayBooks();

        System.out.println("\nFind partial match 'java':");
        Book first = lib.find("java");
        System.out.println(first != null ? first : "No match");

        System.out.println("\nFind all partial matches 'code':");
        for (Book b : lib.findAll("code")) {
            System.out.println(b);
        }

        System.out.println("\nBorrow using partial match 'concurr':");
        lib.borrowBook("concurr");

        System.out.println("\nAvailable after borrow:");
        lib.displayBooks();
    }
}